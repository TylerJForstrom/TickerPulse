# ── TickerPulse environment ─────────────────────────────────────────────
# Copy to .env for local development. In production these live in
# GitHub Actions secrets (worker) and Netlify environment variables (API).
# Every value is optional: with nothing set, TickerPulse runs in demo mode
# off the bundled sample dataset.

# ── Database (Supabase / Neon Postgres, free tier) ──────────────────────
# Postgres connection string. When set, the worker writes results here and
# the Netlify functions read from it. When unset: JSON artifacts (demo mode).
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Supabase REST (used by Netlify functions instead of raw Postgres)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key   # worker only, never in frontend

# ── Reddit API (free; create an app at reddit.com/prefs/apps, type=script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TickerPulse/1.0 (by /u/your-username)
REDDIT_SUBREDDITS=wallstreetbets,stocks,investing,options,CryptoCurrency

# ── StockTwits (public API, no key needed; override politeness here) ────
STOCKTWITS_MAX_SYMBOLS=30

# ── Bluesky (optional; app password from bsky.app settings) ─────────────
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# ── Hugging Face (optional; serverless Inference API for FinBERT) ───────
# Without it the worker runs FinBERT locally (GitHub Actions) or falls back
# to the built-in finance lexicon scorer (zero-dependency demo mode).
HF_TOKEN=

# ── Market data ──────────────────────────────────────────────────────────
# yfinance needs no key. Finnhub is an optional alternative (free tier).
FINNHUB_API_KEY=

# ── Pipeline knobs ───────────────────────────────────────────────────────
PIPELINE_WINDOW_HOURS=24          # trending window
PIPELINE_BUCKET_MINUTES=60        # time-series resolution
SENTIMENT_BACKEND=auto            # auto | finbert | hf_api | lexicon
EMBED_BACKEND=auto                # auto | sentence-transformers | tfidf
